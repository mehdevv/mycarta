{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|facebot|twitterbot|whatsapp|telegrambot|slackbot|linkedinbot|discordbot|googlebot|bingbot|applebot|pinterest|embedly).*"
        }
      ],
      "destination": "/api/social-preview?path=/$1"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

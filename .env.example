# Carta — copy to .env

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Groq — assistant IA carte fidélité (lu depuis .env, pas Supabase secrets)
GROQ_API_KEY=gsk_your_groq_key

# Platform white-label (marketing site, auth, PWA — optional)
# VITE_PLATFORM_NAME=Carta
# VITE_PLATFORM_TAGLINE=Cartes fidélité digitales pour votre commerce
# VITE_PLATFORM_LOGO_URL=https://cdn.example.com/logo.png  # default: src/assets/logo.png
# VITE_PLATFORM_PRIMARY_COLOR=#1A56DB
# VITE_PLATFORM_SECONDARY_COLOR=#0E9F6E
# VITE_PLATFORM_SUPPORT_EMAIL=mycartaapp@gmail.com
# VITE_PLATFORM_SOCIAL_YOUTUBE=https://www.youtube.com/channel/UCXpwTn7UuyVS284a0q24NRA
# VITE_PLATFORM_SOCIAL_INSTAGRAM=https://www.instagram.com/my.carta.app/

# Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets):
# CHARGILY_API_KEY=
# CHARGILY_WEBHOOK_SECRET=
# APP_URL=https://your-domain.com
# PLATFORM_BANK_DETAILS=Virement CCP — RIP ...

# Marketing & app URLs (local dev: npm run dev → http://localhost:5173)
#   /              Landing
#   /tarifs        Pricing anchor (scrolls to /#pricing)
#   /signup        Tenant registration (14-day trial)
#   /:slug/client  Customer enrol
#   /dashboard     Owner dashboard
#   /dashboard/billing  Chargily + BaridiMob receipts
#   /platform      Super-admin (receipts, plan override)
